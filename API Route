import { createNiftySpotProvider, type NiftySpotProvider } from './provider'

type ApiRequest = unknown
interface ApiResponse { statusCode: number; setHeader(name: string, value: string): void; end(body?: string): void }

export function createNiftySpotHandler(provider: NiftySpotProvider = createNiftySpotProvider()) {
  return async (request: ApiRequest, response: ApiResponse) => {
    if ((request as { method?: string }).method !== 'GET') {
      response.statusCode = 405
      response.setHeader('Allow', 'GET')
      response.setHeader('Content-Type', 'application/json')
      response.end(JSON.stringify({ error: 'Method not allowed' }))
      return
    }

    try {
      const spot = await provider.getSpot()
      response.statusCode = 200
      response.setHeader('Content-Type', 'application/json')
      response.setHeader('Cache-Control', 'no-store')
      response.end(JSON.stringify(spot))
    } catch {
      response.statusCode = 503
      response.setHeader('Content-Type', 'application/json')
      response.end(JSON.stringify({ error: 'Nifty spot data is temporarily unavailable.' }))
    }
  }
}
